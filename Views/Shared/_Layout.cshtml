<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Recipe Book</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <header class="site-header">
        <a class="brand" href="/Recipes">🍴 Recipe Book</a>
        <nav>
            <a href="/Recipes">All Recipes</a>
            <a href="/Recipes/Create" class="btn btn-primary btn-sm">+ New Recipe</a>
        </nav>
    </header>

    <main class="container">
        @if (TempData["Flash"] != null)
        {
            <div class="flash" id="flash-msg">
                <span>@TempData["Flash"]</span>
                <button onclick="document.getElementById('flash-msg').remove()" title="Dismiss">✕</button>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="site-footer">
        Recipe Book - built with ASP.NET Core 8 &amp; Entity Framework
    </footer>

</body>
</html>