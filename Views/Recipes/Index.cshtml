@model IEnumerable<Recipe>
@{
    ViewData["Title"] = "All Recipes";
}

<div class="page-header">
    <div>
        <h1>All Recipes</h1>
        <p>@ViewBag.TotalCount recipe@(ViewBag.TotalCount == 1 ? "" : "s") in your collection</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ Add Recipe</a>
</div>

<form method="get" class="filter-bar">
    <input type="text" name="search" value="@ViewBag.Search" placeholder="Search recipes…" />
    <select name="categoryId">
        <option value="">All categories</option>
        @foreach (var item in (SelectList)ViewBag.Categories)
        {
            <option value="@item.Value" selected="@(item.Selected ? "selected" : null)">@item.Text</option>
        }
    </select>
    <button type="submit" class="btn btn-outline">Search</button>
    @if (ViewBag.Search != null || ViewBag.SelectedCategory != null)
    {
        <a asp-action="Index" class="btn btn-outline">Clear</a>
    }
</form>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="icon">🥘</div>
        <h3>No recipes found</h3>
        <p><a asp-action="Create">Add your first recipe</a> to get started.</p>
    </div>
}
else
{
    <div class="recipe-grid">
        @foreach (var r in Model)
        {
            <div class="recipe-card">
                @if (!string.IsNullOrEmpty(r.ImageUrl))
                {
                    <img class="recipe-card-img" src="@r.ImageUrl" alt="@r.Title" loading="lazy" />
                }
                else
                {
                    <div class="recipe-card-img-placeholder">🍽️</div>
                }
                <div class="recipe-card-body">
                    <div class="recipe-card-category">@r.Category?.Name</div>
                    <div class="recipe-card-title">@r.Title</div>
                    <div class="recipe-card-desc">@r.Description</div>
                    <div class="recipe-card-meta">
                        <span>⏱ @r.TotalTimeMinutes min</span>
                        <span>👤 @r.Servings servings</span>
                        <span>🥗 @r.Ingredients.Count ingredients</span>
                    </div>
                </div>
                <div class="recipe-card-actions">
                    <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-outline btn-sm">View</a>
                    <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-outline btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@r.Id" class="btn btn-sm" style="color:var(--danger);border-color:var(--border);">Delete</a>
                </div>
            </div>
        }
    </div>
}